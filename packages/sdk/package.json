{
  "name": "@rinova/proxy-sdk",
  "version": "1.2.1",
  "description": "Proxy subscription to Clash config converter — SDK",
  "type": "module",
  "keywords": ["proxy", "subscription", "clash", "shadowsocks", "v2ray", "trojan", "hysteria2", "vpn", "base64"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parser": {
      "types": "./dist/parser.d.ts",
      "import": "./dist/parser.js"
    },
    "./fetch": {
      "types": "./dist/fetch.d.ts",
      "import": "./dist/fetch.js"
    },
    "./builder": {
      "types": "./dist/builder.d.ts",
      "import": "./dist/builder.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/parser.test.ts src/__tests__/builder.test.ts src/__tests__/sdk.test.ts",
    "test:server": "tsx --test src/__tests__/server.test.ts",
    "test:all": "pnpm test && pnpm test:server"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "js-yaml": "^5.2.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.25.0"
}
